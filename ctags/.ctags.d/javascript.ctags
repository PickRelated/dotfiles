# vim: ft=conf

# Show line numbers
-n
# Delete all fields after line numbers
# --fields=
# Generate tags from filenames
--extras=+f

# Disable default const tags
--kinds-JavaScript=-C
# Override default const tags and call them consts instead of C. Notice [ \t][^r]. There can not be two or more spaces before require.
--regex-JavaScript=/\b(const|let|var)[ \t]+([a-zA-Z0-9_]+)[ \t]=[ \t][^r]/\2/consts/
